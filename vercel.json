{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "IBM_API_KEY": "@ibm_api_key",
    "WATSONX_PROJECT_ID": "@watsonx_project_id",
    "WATSONX_URL": "@watsonx_url"
  }
}